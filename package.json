{
  "name": "clipmyboard",
  "version": "0.1.0",
  "description": "Cross-platform clipboard manager with a slim shortcut drawer.",
  "author": "ClipMyBoard contributors",
  "license": "MIT",
  "private": true,
  "main": "dist/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "wait-on tcp:5173 && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run clean && npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup src/main/index.ts src/preload/index.ts --format cjs --platform node --target node20 --external electron --out-dir dist --clean=false",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src vite.config.ts vitest.config.ts",
    "test": "vitest run",
    "clean": "rimraf dist release",
    "install": "node scripts/install-app.mjs",
    "package": "npm run build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "nanoid": "^5.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.21.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.26.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.2"
  }
}
